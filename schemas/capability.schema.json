{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Capability Record",
  "type": "object",
  "required": ["type", "schema_version", "stack", "surface", "maps"],
  "properties": {
    "schema_version": { "const": "2.0" },
    "type": { "const": "capability" },
    "stack": { "type": "string" },
    "surface": { "enum": ["HTTP/REST", "TanStack Start route"] },
    "maps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source"],
        "properties": {
          "source": { "type": "string" }
        }
      }
    }
  }
}
