{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment Record",
  "type": "object",
  "required": ["id", "schema_version", "type", "status", "created_at", "updated_at", "source_refs", "goal", "hypothesis", "knowledge_pack_ids", "method", "success_metrics", "result", "agent_outcome", "product_outcome", "observations", "promotion_review"],
  "properties": {
    "id": { "type": "string" },
    "schema_version": { "type": "string" },
    "type": { "const": "experiment" },
    "status": { "enum": ["draft", "reviewed", "approved", "rejected"] },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "source_refs": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "goal": { "type": "string" },
    "hypothesis": { "type": "string" },
    "knowledge_pack_ids": { "type": "array", "items": { "type": "string" } },
    "method": { "type": "array", "items": { "type": "string" } },
    "success_metrics": { "type": "array", "items": { "type": "string" } },
    "result": { "type": "string" },
    "agent_outcome": { "type": "string" },
    "product_outcome": { "type": "string" },
    "observations": { "type": "array" },
    "promotion_review": { "type": "array" },
    "assurance_level": { "enum": ["evidence-reviewed", "static-verified", "install-verified", "runtime-verified"] },
    "scope": { "enum": ["planning", "install", "runtime", "product", "schema-improvement"] },
    "claim_refs": { "type": "array", "items": { "type": "string" } },
    "risk_refs": { "type": "array", "items": { "type": "string" } },
    "output_level": { "enum": ["none", "docs-only", "metadata-only", "runtime-captured", "product-code"] },
    "output_capture": {
      "type": "object",
      "properties": {
        "allowed_outputs": { "type": "array", "items": { "type": "string" } },
        "blocked_outputs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "verification": {
      "type": "object",
      "required": ["claim_refs", "from_state", "to_state", "output_level", "requires_human_approval", "approval_status"],
      "properties": {
        "claim_refs": { "type": "array", "items": { "type": "string" } },
        "from_state": { "enum": ["imported-prior", "evidence-reviewed", "static-verified", "install-verified", "runtime-verified", "product-approved", "rejected"] },
        "to_state": { "enum": ["imported-prior", "evidence-reviewed", "static-verified", "install-verified", "runtime-verified", "product-approved", "rejected"] },
        "output_level": { "enum": ["none", "docs-only", "metadata-only", "runtime-captured", "product-code"] },
        "requires_human_approval": { "type": "boolean" },
        "approval_status": { "enum": ["not-required", "requested", "approved", "rejected"] }
      }
    }
  }
}
