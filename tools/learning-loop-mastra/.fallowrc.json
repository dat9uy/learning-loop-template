{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",

  "entry": [
    "mastra/server.js",
    "mastra/create-loop-tool.js",
    "mastra/create-loop-workflow.js",
    "mastra/create-loop-agent.js",
    "mastra/handler-adapter.js",
    "mastra/agents/load-agents-manifest.js",
    "mastra/schemas.js",
    "mastra/schema-parity.js",
    "storage.js",
    "scripts/**",
    "core/hint-renderer.js"
  ],

  "dynamicallyLoaded": [
    "tools/handlers/**/*.js",
    "hooks/universal/**/*.js",
    "hooks/universal/**/*.cjs",
    "interface/**/*.js",
    "__tests__/with-mcp-server.js",
    "__tests__/helpers/**/*.cjs",
    "tools/lib/patch-hints.js"
  ],

  "ignorePatterns": [
    "__tests__/fixtures/**",
    "__tests__/phase-e-foundation/fixtures/**",
    "tools/handlers/evals/**",
    "tools/handlers/references/**",
    "tools/handlers/fixtures/**",
    "tools/handlers/scripts/**",
    "scout/pipeline/**",
    "plans/**",
    "docs/**",
    "**/*.test.js",
    "**/*.test.cjs",
    "**/*.spec.js",
    "**/*.spec.cjs"
  ],

  "ignoreExports": [
    {
      "file": "core/meta-state.js",
      "exports": [
        "FILE_INDEX_FILENAME",
        "getFileIndexPath",
        "_resetFileIndexCacheForTests"
      ]
    },
    {
      "file": "tools/lib/gate-logging.js",
      "exports": [
        "appendGateLog",
        "logToolCall"
      ]
    },
    {
      "file": "tools/lib/patch-hints.js",
      "exports": [
        "listMutableFieldsCsv"
      ]
    }
  ],

  "rules": {
    "unused-files": "error",
    "unused-exports": "warn",
    "unused-dependencies": "error",
    "unused-dev-dependencies": "warn",
    "circular-dependencies": "error",
    "boundary-violation": "off",
    "unresolved-imports": "error",
    "duplicate-exports": "error",
    "stale-suppressions": "warn"
  },

  "audit": {
    "gate": "new-only"
  }
}
