{
  "version": "1.0.0",
  "server": "learning-loop-mcp",
  "groups": {
    "gate": {
      "description": "Safety checks — call BEFORE any write operation",
      "tools": ["gate_check", "gate_check_recurrence", "gate_mark_preflight", "gate_override", "runtime_state_record", "runtime_state_pause", "runtime_state_resume", "runtime_state_stop"],
      "ordering": "mandatory-first",
      "cache_ttl": 0
    },
    "workflow": {
      "description": "Learning-loop workflow orchestration",
      "tools": [
        "workflow_generate_prompt",
        "workflow_notify_artifact",
        "workflow_trigger"
      ],
      "ordering": "linear",
      "typical_chain": [
        "workflow_notify_artifact"
      ]
    },
    "meta_state": {
      "description": "Meta-state registry for loop self-awareness findings",
      "tools": [
        "meta_state_report",
        "meta_state_list",
        "meta_state_ack",
        "meta_state_resolve",
        "meta_state_promote_rule",
        "meta_state_sweep",
        "meta_state_log_change",
        "meta_state_patch",
        "meta_state_derive_status",
        "meta_state_check_grounding",
        "meta_state_refresh_file_index",
        "meta_state_query_drift",
        "meta_state_batch",
        "meta_state_archive",
        "meta_state_relationship_validate",
        "meta_state_propose_design",
        "meta_state_relationships",
        "meta_state_re_verify",
        "meta_state_supersede"
      ],
      "ordering": "any"
    },
    "introspection": {
      "description": "Discover the loop's operational surface, active rules, and curated instructions",
      "tools": ["loop_describe", "loop_get_instruction", "runtime_state_read"],
      "ordering": "any",
      "typical_chain": ["loop_describe", "loop_get_instruction"]
    },
    "runtime_agnostic": {
      "description": "Audit a feature's compliance with the runtime-agnostic pattern (shim-not-fork + cross-surface-iteration). Call when adding a new feature.",
      "tools": ["check_runtime_agnostic"],
      "ordering": "any"
    }
  },
  "quickstart": {
    "meta_state_query": [
      { "tool": "loop_describe", "tier": "warm" },
      { "tool": "meta_state_list", "entry_kind": "finding" },
      { "tool": "meta_state_query_drift" }
    ]
  }
}
