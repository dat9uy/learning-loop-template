# Learning Loop Template — environment variables
#
# Copy this file to `.env` and uncomment the variables you want to set.
# The project reads these at runtime; defaults are sensible for local dev.

# ─── Plan 2 — Mastra storage driver (D5+D6) ────────────────────────────────
# native  → file-backed LibSQL (default, production)
# web     → @libsql/client/web (no native binding; CI fallback)
# memory  → in-memory SQLite (CI safety net; Test 3 of storage-parity SKIPS)
MASTRA_STORAGE_DRIVER=native

# ─── Meta-surface (meta-state.jsonl) ───────────────────────────────────────
# GATE_ROOT — overrides the project's gate root directory (default: project root).
# Used by tests to isolate per-test GATE_ROOTs in tmpdir.
# GATE_ROOT=

# GATE_MARKER_PATH — path to a JSON file the inbound gate reads to detect
# operator state changes (default: `.claude/coordination/.last-operator-message`).
# GATE_MARKER_PATH=

# GATE_COORD_DIR — overrides the coordination directory (default: `.claude/coordination/`).
# GATE_COORD_DIR=

# GATE_RECURSION_DRY_RUN — when "1", the recurrence tracker logs but does not
# auto-file findings (used in CI to surface patterns without polluting the registry).
# GATE_RECURSION_DRY_RUN=

# ─── Operator-gated tools ─────────────────────────────────────────────────
# OPERATOR_MODE — when "1" or "true", unlocks destructive operator-only tools
# (meta_state_sweep with apply=true, meta_state_supersede, meta_state_promote_rule).
# Default: unset (most tools refuse destructive ops).
# OPERATOR_MODE=

# META_STATE_VERIFY_EXEC — when "1" or "true", allows meta_state_re_verify to
# actually run verification commands (default: off; dry-run only).
# META_STATE_VERIFY_EXEC=

# META_STATE_STALENESS_WINDOW_MS — staleness window for findings (default: 7 days).
# META_STATE_STALENESS_WINDOW_MS=604800000

# META_STATE_BATCH_LIMIT — max ops in a single meta_state_batch call (default: 500).
# META_STATE_BATCH_LIMIT=500

# ─── Loop discoverability ─────────────────────────────────────────────────
# LL_LOOP_INJECT_TIER — tier for the SessionStart hook's discoverability_hints
# injection. Set to "summary" to suppress hints for context-budgeted sessions
# (logged as a hint-downgrade finding per session). Default: warm.
# LL_LOOP_INJECT_TIER=warm

# ─── Gate response mode ───────────────────────────────────────────────────
# GATE_RESPONSE_MODE — controls non-artifact gate behavior:
#   warn (default) — allow the write, emit JSON warning
#   escalate       — block the write, require operator approval
# GATE_RESPONSE_MODE=warn

# ─── Scout helper ─────────────────────────────────────────────────────────
# SCOUT_BUDGET_LATENCIES — JSON object overriding default scout latency budgets
# (e.g., '{"indexExtract": 50, "compactTier": 200}'). Default: built-in.
# SCOUT_BUDGET_LATENCIES=

# ─── Plan 3 — Mastra agent model (D4+D7) ─────────────────────────────────
# KIMI_API_KEY — API key for the Kimi router (required at runtime for agents).
# The Mastra model router auto-injects this when an agent uses kimi-for-coding.
# KIMI_API_KEY=sk-your-kimi-api-key-here

# MASTRA_AGENT_MODEL — overrides the model for all 3 agents (optional).
# Format: provider/model (e.g., kimi-for-coding/k2p6).
# Lookup order: (1) per-agent agents-manifest.json model field,
#               (2) this env var, (3) code default kimi-for-coding/k2p6.
# MASTRA_AGENT_MODEL=kimi-for-coding/k2p6
