{
  "workflows": {
    "evidence-changed": {
      "triggers": ["records/*/evidence/**"],
      "change_types": ["created", "updated"],
      "commands": [
        ["node", "tools/extract-index-cli.js"],
        ["node", "tools/validate-records-cli.js"]
      ]
    },
    "observation-changed": {
      "triggers": ["records/observations/**"],
      "change_types": ["created", "updated"],
      "commands": [
        ["node", "tools/validate-records-cli.js"]
      ]
    },
    "capability-changed": {
      "triggers": ["records/*/capabilities/**"],
      "change_types": ["created", "updated"],
      "commands": [
        ["node", "tools/validate-records/validate-records.js"],
        ["node", "tools/generate-capabilities/generate-capabilities.js", "--dry-run"]
      ]
    },
    "index-changed": {
      "triggers": ["records/*/index/**"],
      "change_types": ["created", "updated"],
      "commands": [
        ["node", "tools/validate-records-cli.js"]
      ]
    }
  }
}
