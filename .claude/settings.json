{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/coordination/hooks/recurrence-check-on-start.cjs"
          },
          {
            "type": "command",
            "command": "node tools/learning-loop-mastra/hooks/universal/session-start-inject-discoverability.cjs"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/coordination/hooks/inbound-state-gate.cjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/coordination/hooks/write-coordination-gate.cjs"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/coordination/hooks/bash-coordination-gate.cjs"
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": false
}
