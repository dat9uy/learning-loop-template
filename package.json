{
  "name": "learning-loop-template",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "imports": {
    "#mastra/*": "./tools/learning-loop-mastra/*",
    "#lib/*": "./tools/lib/*"
  },
  "scripts": {
    "bootstrap:api": "cd product/api && uv sync && bash scripts/install-vnstock.sh",
    "dev:api": "cd product/api && uv run uvicorn src.main:app --reload --port 8000",
    "dev:web": "cd product/web && pnpm dev",
    "dev": "(trap 'kill 0' EXIT; pnpm dev:api & pnpm dev:web)",
    "smoke:vci": "cd product/api && VNSTOCK_SMOKE_TEST_ALLOW_LIVE=1 uv run pytest -m network -v tests/test_vci_smoke.py",
    "smoke:mastracode": "node scripts/probe-mastracode.cjs",
    "test": "vitest run && node tools/scripts/sanitize-coverage.mjs",
    "test:debug": "vitest run tools/learning-loop-mastra/__tests__/debug/",
    "test:cold-session": "vitest run tools/learning-loop-mastra/__tests__/legacy-mcp/cold-session-discoverability.test.cjs",
    "check:freshness": "vitest run tools/learning-loop-mastra/__tests__/freshness/",
    "fallow:gate": "fallow audit --root tools/learning-loop-mastra --gate new-only --changed-since origin/main --coverage \"$PWD/coverage/coverage-final.json\" --coverage-root \"$PWD/tools/learning-loop-mastra\" --dead-code-baseline \"$PWD/tools/learning-loop-mastra/baselines/fallow/dead-code-baseline.json\" --health-baseline \"$PWD/tools/learning-loop-mastra/baselines/fallow/health-baseline.json\" --dupes-baseline \"$PWD/tools/learning-loop-mastra/baselines/fallow/dupes-baseline.json\"",
    "gate:self-verify": "node tools/learning-loop-mastra/scripts/gate-self-verify.mjs",
    "gate:server": "node tools/learning-loop-mastra/mastra/server.js"
  },
  "dependencies": {
    "@libsql/client": "0.17.4",
    "@mastra/core": "1.42.0",
    "@mastra/libsql": "1.13.0",
    "@mastra/mcp": "1.10.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "proper-lockfile": "4.1.2",
    "yaml": "^2.8.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "fallow": "3.3.0",
    "mastracode": "^0.26.0",
    "simple-git-hooks": "^2.13.1",
    "vitest": "^4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm test && pnpm fallow:gate"
  }
}
