{
  "name": "learning-loop-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bootstrap:api": "cd product/api && uv sync && bash scripts/install-vnstock.sh",
    "dev:api": "cd product/api && uv run uvicorn src.main:app --reload --port 8000",
    "dev:web": "cd product/web && pnpm dev",
    "dev": "(trap 'kill 0' EXIT; pnpm dev:api & pnpm dev:web)",
    "smoke:vci": "cd product/api && VNSTOCK_SMOKE_TEST_ALLOW_LIVE=1 uv run pytest -m network -v tests/test_vci_smoke.py",
    "validate:records": "node tools/validate-records/validate-records.js",
    "verify:claim": "node tools/claim-verification/verify-claim.js",
    "generate:docs": "node tools/generate-docs/generate-docs.js",
    "list:verified": "bash tools/list-verified/list-verified.sh",
    "test": "node --test 'tools/**/*.test.js' '.claude/coordination/__tests__/*.test.cjs'",
    "check:budget": "node tools/check-budget/check-budget.js",
    "clean:sandbox": "bash product/api/scripts/cleanup-sandbox.sh",
    "generate:capabilities": "node tools/generate-capabilities/generate-capabilities.js",
    "check": "pnpm generate:capabilities --dry-run && pnpm validate:records && pnpm test",
    "gate:server": "node tools/constraint-gate/server.js",
    "extract:index": "node tools/extract-index/extract-index.js",
    "list:probes": "node tools/list-probes/list-probes.js",
    "search:index": "node tools/search-index/search-index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  }
}
